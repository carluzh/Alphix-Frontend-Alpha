# Alphix Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# WalletConnect Configuration
# ============================================
# Get your project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# Subgraph Endpoints (Goldsky-hosted)
# ============================================
# REQUIRED: lib/subgraph-url-helper.ts throws if the env var for the active
# network is unset — there are no hardcoded fallback URLs.
# Use the stable Goldsky tag URLs (note casing: Base tag is "Prod", Arbitrum tag is "prod").
#
# Base (single subgraph indexing all Base pools)
SUBGRAPH_URL_BASE_LVRFEE=https://api.goldsky.com/api/public/project_cmktm2w8l5s0k01u9fz2yetrw/subgraphs/alphix-base-lvrfee/Prod/gn
# Arbitrum One
SUBGRAPH_URL_ARBITRUM_ALPHIX=https://api.goldsky.com/api/public/project_cmktm2w8l5s0k01u9fz2yetrw/subgraphs/alphix-arbitrum/prod/gn

# ============================================
# Maintenance Mode
# ============================================
# Set to 'true' to enable maintenance mode, 'false' or remove to disable
MAINTENANCE=false

# ============================================
# RPC Configuration
# ============================================
# Premium RPC providers recommended (Alchemy, DRPC, QuickNode)
# Base Mainnet
NEXT_PUBLIC_RPC_URL=your_base_rpc_url_here
# Arbitrum One
NEXT_PUBLIC_ARBITRUM_RPC_URL=your_arbitrum_rpc_url_here

# ============================================
# Uniswap Liquidity API
# ============================================
# REQUIRED: lib/liquidity/uniswap-api/client.ts throws without it.
# Used by the LP prepare-tx routes (mint/increase/decrease) via Uniswap's hosted API.
UNISWAP_API_KEY=your_uniswap_api_key_here

# ============================================
# Upstash Redis (server-side rate limiting + caching)
# ============================================
# Optional: lib/api/ratelimit.ts and lib/cache/redis.ts gracefully degrade if unset.
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# ============================================
# App URL
# ============================================
# REQUIRED outside Vercel: app/api/graphql/route.ts and lib/apollo/client.ts throw
# without it (on Vercel, VERCEL_URL is used automatically). Also used by
# layout/sitemap/robots with an alphix.fi fallback.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# AlphixBackend API (for Portfolio/Yield data)
# ============================================
# URL to the AlphixBackend service (portfolio charts, position fees, pool history)
# Development: http://localhost:3001
# Production: https://api.alphix.fi (or your backend deployment URL)
NEXT_PUBLIC_ALPHIX_BACKEND_URL=https://api.alphix.fi
# Optional WebSocket override for the backend real-time feed (lib/backend-client.ts);
# defaults to the ws(s):// form of NEXT_PUBLIC_ALPHIX_BACKEND_URL when unset.
# NEXT_PUBLIC_ALPHIX_WS_URL=wss://api.alphix.fi

# ============================================
# Sentry Source-Map Upload (CI / Vercel only)
# ============================================
# The @sentry/nextjs bundler plugin auto-reads these and self-activates source-map
# upload only when ALL THREE are set. Leave unset for local dev (builds still work,
# upload is simply skipped). Set them as CI / Vercel environment variables.
# The auth token is a secret and MUST NEVER be committed.
# SENTRY_ORG=your_sentry_org_slug
# SENTRY_PROJECT=your_sentry_project_slug
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
