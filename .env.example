# Alphix Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# WalletConnect Configuration
# ============================================
# Get your project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_PROJECT_ID=your_walletconnect_project_id_here

# ============================================
# Authentication
# ============================================
# Password for maintenance mode bypass
SITE_PASSWORD=your_secure_password_here

# ============================================
# Subgraph Endpoints (Goldsky-hosted)
# ============================================
# Optional: Override the hardcoded Goldsky fallback URLs in lib/subgraph-url-helper.ts
# If not set, the app uses the Goldsky URLs directly.
#
# Base Mainnet
# SUBGRAPH_URL_MAINNET_ALPHIX=https://api.goldsky.com/.../alphix-hook-mainnet/prod/gn
# Arbitrum One
# SUBGRAPH_URL_ARBITRUM_ALPHIX=https://api.goldsky.com/api/public/project_cmktm2w8l5s0k01u9fz2yetrw/subgraphs/alphix-arbitrum/v0.0.4/gn
# Base LVRFee (AlphixLVRFee hook pools)
# SUBGRAPH_URL_BASE_LVRFEE=https://api.goldsky.com/api/public/project_cmktm2w8l5s0k01u9fz2yetrw/subgraphs/alphix-base-lvrfee/v0.0.1/gn

# ============================================
# Network Mode
# ============================================
# Set to 'mainnet' for Base, 'arbitrum' for Arbitrum One
NEXT_PUBLIC_DEFAULT_NETWORK=mainnet

# ============================================
# Maintenance Mode
# ============================================
# Set to 'true' to enable maintenance mode, 'false' or remove to disable
MAINTENANCE=false

# ============================================
# ReCAPTCHA Configuration
# ============================================
# Get your keys from https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ============================================
# RPC Configuration
# ============================================
# Premium RPC providers recommended (Alchemy, DRPC, QuickNode)
# Base Mainnet
NEXT_PUBLIC_RPC_URL=your_base_rpc_url_here
# Arbitrum One
NEXT_PUBLIC_ARBITRUM_RPC_URL=your_arbitrum_rpc_url_here

# ============================================
# Alchemy API (for Token Balances)
# ============================================
# Get your API key from https://www.alchemy.com/
# Used by /api/tokens/balances to fetch user token holdings with metadata
ALCHEMY_API_KEY=your_alchemy_api_key_here

# ============================================
# Backend API (for Points & Referral operations)
# ============================================
# URL to the Alphix backend API (points, referral, etc.)
# All points/referral data is fetched through the backend — no direct Redis access.
NEXT_PUBLIC_BACKEND_API_URL=https://api.alphix.io

# ============================================
# AlphixBackend API (for Portfolio/Yield data)
# ============================================
# URL to the AlphixBackend service (portfolio charts, position fees, pool history)
# Development: http://localhost:3001
# Production: https://api.alphix.fi (or your backend deployment URL)
NEXT_PUBLIC_ALPHIX_BACKEND_URL=https://api.alphix.fi

# ============================================
# Optional: Supabase Configuration (DEPRECATED - Not currently used)
# ============================================
# Uncomment if you need Supabase integration
# NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_JWT_SECRET=your_supabase_jwt_secret
